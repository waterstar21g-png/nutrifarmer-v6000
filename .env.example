# V6000 — V5000(nutrifarmer-v5000)과 동일한 값 사용 (DATABASE_URL, AUTH, R2, CDN 등)
# 로컬: cp ../nutrifarmer-v5000/.env.local .env.local 후 NEXT_PUBLIC_SITE_URL 만 변경

# DB (Neon) — V5000과 동일
DATABASE_URL=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# 인증 — V5000과 동일
AUTH_SESSION_SECRET=

# R2 미디어 — V5000과 동일
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nutrifarmer-media
R2_PUBLIC_ACCESS=true

# CDN — V5000과 동일 (미설정 시 media.nutrifarmer.kr 기본값)
NEXT_PUBLIC_CDN_URL=https://media.nutrifarmer.kr

# V6000 전용 (V5000과 다름)
NEXT_PUBLIC_SITE_URL=http://localhost:6000
NEXT_PUBLIC_V5000_WRITE_URL=https://www.nutrifarmer.kr/write

# 메일 (선택) — V5000과 동일
RESEND_API_KEY=
MAIL_FROM=
