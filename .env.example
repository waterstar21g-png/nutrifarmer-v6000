# V6000 — V5000(nutrifarmer-v5000)과 동일한 값 사용 (DATABASE_URL, AUTH, R2, CDN 등)
# 로컬: cp ../nutrifarmer-v5000/.env.local .env.local 후 NEXT_PUBLIC_SITE_URL 만 변경

# DB (Neon) — V5000과 동일
DATABASE_URL=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# 인증 — V5000과 동일
AUTH_SESSION_SECRET=

# R2 미디어 — V5000과 동일
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nutrifarmer-media
R2_PUBLIC_ACCESS=true

# CDN — V5000과 동일 (미설정 시 media.nutrifarmer.kr 기본값)
NEXT_PUBLIC_CDN_URL=https://media.nutrifarmer.kr

# V6000 전용 (V5000과 다름)
NEXT_PUBLIC_SITE_URL=http://localhost:6000
NEXT_PUBLIC_V5000_WRITE_URL=https://www.nutrifarmer.kr/write

# 상품 스카우트 — OpenAI 비전 (상품 이미지 인식)
OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o-mini

# 상품 스카우트 — 아이템스카우트 B2B API (https://itemscout.io/api 신청)
# 미설정 시 데모 데이터로 동작합니다.
ITEMSCOUT_API_KEY=
# ITEMSCOUT_API_BASE_URL=https://api.itemscout.io
# ITEMSCOUT_KEYWORD_PATH=/api/open/v1/keyword
# ITEMSCOUT_AUTH_HEADER=Authorization
# ITEMSCOUT_AUTH_SCHEME=Bearer

# 메일 (선택) — V5000과 동일
RESEND_API_KEY=
MAIL_FROM=
